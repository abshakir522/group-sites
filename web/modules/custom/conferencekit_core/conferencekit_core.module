<?php

/**
 * @file
 * Hooks for the Conference Kit Core module.
 */

use Drupal\Component\Utility\UrlHelper;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Entity\Display\EntityFormDisplayInterface;
use Drupal\group\Entity\GroupInterface;
use Drupal\group\Entity\GroupRelationshipInterface;

/**
 * Implements hook_views_data_alter().
 */
function conferencekit_core_views_data_alter(array &$data): void {
  if (!isset($data['node_field_data'])) {
    return;
  }

  $data['node_field_data']['conferencekit_session_day'] = [
    'title' => t('Session day'),
    'help' => t('Filters sessions by day, derived from the current domain group conference start date and the session Smart Date start value.'),
    'filter' => [
      'id' => 'conferencekit_session_day',
      'title' => t('Session day'),
      'field' => 'conferencekit_session_day',
    ],
  ];
}

/**
 * Gets the group assigned to the active domain.
 */
function conferencekit_core_get_group_from_active_domain(): ?GroupInterface {
  if (!\Drupal::hasService('domain.negotiator')) {
    return NULL;
  }

  $domain = \Drupal::service('domain.negotiator')->getActiveDomain();
  if (!$domain) {
    return NULL;
  }

  $group_uuid = $domain->getThirdPartySetting('group_context_domain', 'group_uuid');
  if (!$group_uuid) {
    return NULL;
  }

  $group = \Drupal::service('entity.repository')->loadEntityByUuid('group', $group_uuid);
  return $group instanceof GroupInterface ? $group : NULL;
}

/**
 * Implements hook_entity_form_display_alter().
 */
function conferencekit_core_entity_form_display_alter(EntityFormDisplayInterface $form_display, array $context): void {
  if (($context['entity_type'] ?? NULL) !== 'canvas_page'
    || ($context['bundle'] ?? NULL) !== 'canvas_page') {
    return;
  }

  $field_definition = \Drupal::service('entity_field.manager')->getFieldDefinitions('canvas_page', 'canvas_page')['field_ck_microsite_path'] ?? NULL;
  if ($field_definition === NULL) {
    return;
  }

  $form_display->setComponent('field_ck_microsite_path', [
    'type' => 'string_textfield',
    'weight' => 31,
    'region' => 'content',
    'settings' => [
      'size' => 60,
      'placeholder' => '/speakers',
    ],
  ]);
}

/**
 * Implements hook_entity_presave().
 */
function conferencekit_core_entity_presave(EntityInterface $entity): void {
  if ($entity->getEntityTypeId() !== 'canvas_page'
    || !$entity->hasField('field_ck_microsite_path')) {
    return;
  }

  $entity->set('field_ck_microsite_path', _conferencekit_core_normalize_microsite_path((string) $entity->get('field_ck_microsite_path')->value));
}

/**
 * Implements hook_entity_insert().
 */
function conferencekit_core_entity_insert(EntityInterface $entity): void {
  _conferencekit_core_attach_entity_to_active_group($entity);
}

/**
 * Implements hook_entity_update().
 */
function conferencekit_core_entity_update(EntityInterface $entity): void {
  _conferencekit_core_attach_entity_to_active_group($entity);
}

/**
 * Adds newly saved content to the group resolved from the active domain.
 */
function _conferencekit_core_attach_entity_to_active_group(EntityInterface $entity): void {
  if ($entity->id() === NULL) {
    return;
  }

  $group = conferencekit_core_get_group_from_active_domain();
  if (!$group instanceof GroupInterface) {
    return;
  }

  $plugin_id = _conferencekit_core_get_group_relation_plugin_id($entity, $group);
  if ($plugin_id === NULL) {
    return;
  }

  _conferencekit_core_ensure_entity_group_relationship($entity, $group, $plugin_id);
}

/**
 * Ensures an entity has a relationship to the active group.
 */
function _conferencekit_core_ensure_entity_group_relationship(EntityInterface $entity, GroupInterface $group, string $plugin_id): ?GroupRelationshipInterface {
  $relationship_storage = \Drupal::entityTypeManager()->getStorage('group_relationship');
  $relationships = $relationship_storage->loadByEntity($entity, $plugin_id);

  foreach ($relationships as $relationship) {
    if ($relationship instanceof GroupRelationshipInterface
      && (int) $relationship->get('gid')->target_id === (int) $group->id()) {
      return $relationship;
    }
  }

  if ($relationships) {
    return NULL;
  }

  $relationship = $group->addRelationship($entity, $plugin_id);
  return $relationship instanceof GroupRelationshipInterface ? $relationship : NULL;
}

/**
 * Gets the installed group relation plugin ID that supports an entity.
 */
function _conferencekit_core_get_group_relation_plugin_id(EntityInterface $entity, GroupInterface $group): ?string {
  $plugin_id = match ($entity->getEntityTypeId()) {
    'canvas_page' => 'conferencekit_canvas_page',
    'node' => 'group_node:' . $entity->bundle(),
    default => NULL,
  };

  if ($plugin_id === NULL || !$group->getGroupType()->hasPlugin($plugin_id)) {
    return NULL;
  }

  return $plugin_id;
}

/**
 * Normalizes a Canvas page microsite path value for storage.
 */
function _conferencekit_core_normalize_microsite_path(string $path): ?string {
  $path = trim($path);
  if ($path === '') {
    return NULL;
  }

  if (str_starts_with($path, 'internal:')) {
    $path = substr($path, strlen('internal:'));
  }

  if ($path === '' || $path === '<front>' || $path === '/') {
    return NULL;
  }

  if (UrlHelper::isExternal($path)) {
    return NULL;
  }

  $path = '/' . ltrim($path, '/');
  return rtrim($path, '/') ?: NULL;
}
