            </svg>
        </div>

        <!-- Links -->
        <div
            class="nav__option--links uppercase load hidden flex flex-col justify-between xl:h-fit min-h-100 h-[calc(100vh-190px)] max-h-142.5 border-2 rounded-2xl border-secondary bg-body-bg top-full mt-2.5 xl:mt-0 absolute right-0 left-0 shadow-2xl px-6 py-8 xl:static xl:flex xl:flex-row xl:min-h-full xl:border-0 xl:shadow-none xl:gap-[clamp(28px,2.2vw,40px)] xl:bg-transparent xl:p-0 xl:items-center">
            {{ page.primary_menu }}
            <div class="xl:hidden flex flex-col gap-5">
                {% if page.top_right_actions %}
                    {{ page.top_right_actions }}
                {% endif %}
            </div>
        </div>
    </div>
    <!-- Contact -->
    <div class="hidden xl:flex gap-5 items-center">
        {% if page.top_right_actions %}
          {{ page.top_right_actions }}
        {% endif %}
    </div>
  </div>
</nav>
