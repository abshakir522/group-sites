{#
/**
 * @file
 * DrupalCamp-style accordion item with Alpine open/close behavior.
 */
#}

{% set is_open = default_open|default(false) %}

<div
  {{ attributes
    .addClass('relative w-full pr-[clamp(46px,5vw,80px)] p-[clamp(12px,2.5vw,40px)] border border-secondary/50 rounded-2xl bg-secondary/5')
  }}
  x-data="{ activeIndex: {{ is_open ? 0 : 'null' }} }"
>
  <button
    type="button"
    class="absolute inset-0 z-10 cursor-pointer text-left"
    @click="activeIndex = activeIndex === 0 ? null : 0"
    x-bind:aria-expanded="activeIndex === 0"
    aria-label="{{ title|default('Toggle accordion') }}"
  ></button>

  <svg
    class="absolute top-4 right-6 transition-all duration-500 pointer-events-none text-body-title/80"
    x-bind:class="activeIndex === 0 ? 'rotate-0' : 'rotate-180'"
    width="30"
    height="28"
    viewBox="0 0 30 28"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <path d="M23 18L15 10L7 18" stroke="currentColor" stroke-opacity="0.8" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path>
  </svg>

  {% if title %}
    <h4 class="text-h4 relative z-20 pointer-events-none">{{ title }}</h4>
  {% endif %}

  {% if location %}
    <div class="flex gap-2.5 items-center pt-3 relative z-20 pointer-events-none">
      <svg class="text-secondary" width="11" height="14" viewBox="0 0 11 14" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path d="M10 5.5C10 4.30653 9.52589 3.16193 8.68198 2.31802C7.83807 1.47411 6.69347 1 5.5 1C4.30653 1 3.16193 1.47411 2.31802 2.31802C1.47411 3.16193 1 4.30653 1 5.5C1 7.34531 2.47656 9.75156 5.5 12.6344C8.52344 9.75 10 7.34375 10 5.5ZM5.5 14C1.83333 10.6667 0 7.83333 0 5.5C0 4.04131 0.579463 2.64236 1.61091 1.61091C2.64236 0.579463 4.04131 0 5.5 0C6.95869 0 8.35764 0.579463 9.38909 1.61091C10.4205 2.64236 11 4.04131 11 5.5C11 7.83333 9.16667 10.6667 5.5 14Z" fill="currentColor"></path>
        <path d="M5.5 7C5.89782 7 6.27936 6.84196 6.56066 6.56066C6.84196 6.27936 7 5.89782 7 5.5C7 5.10218 6.84196 4.72064 6.56066 4.43934C6.27936 4.15804 5.89782 4 5.5 4C5.10218 4 4.72064 4.15804 4.43934 4.43934C4.15804 4.72064 4 5.10218 4 5.5C4 5.89782 4.15804 6.27936 4.43934 6.56066C4.72064 6.84196 5.10218 7 5.5 7ZM5.5 8C4.83696 8 4.20107 7.73661 3.73223 7.26777C3.26339 6.79893 3 6.16304 3 5.5C3 4.83696 3.26339 4.20107 3.73223 3.73223C4.20107 3.26339 4.83696 3 5.5 3C6.16304 3 6.79893 3.26339 7.26777 3.73223C7.73661 4.20107 8 4.83696 8 5.5C8 6.16304 7.73661 6.79893 7.26777 7.26777C6.79893 7.73661 6.16304 8 5.5 8Z" fill="currentColor"></path>
      </svg>
      <p class="text-body-title/80">{{ location }}</p>
    </div>
  {% endif %}

  <div
    x-ref="panel0"
    x-bind:style="activeIndex === 0 ? 'max-height:' + $refs.panel0.scrollHeight + 'px; opacity:1;' : 'max-height:0; opacity:0;'"
    class="overflow-hidden transition-all duration-500 relative z-20 pointer-events-none"
  >
    {% if description %}
      <div class="text-body-title/80 text-sm leading-5.5 md:text-base md:leading-6.5 pb-8 pt-6">
        {{ description }}
      </div>
    {% endif %}

    {% if speaker %}
      <div class="text-body-title/80 pt-5 border-t-[0.5px] border-secondary flex items-center gap-7.5">
        <p class="text-sm">{{ 'Speaker'|t }}:</p>
        <p class="text-sm py-1 px-2 bg-tertiary/40">{{ speaker }}</p>
      </div>
    {% endif %}
  </div>
</div>
